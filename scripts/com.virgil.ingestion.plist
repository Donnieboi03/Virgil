<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.virgil.ingestion</string>

    <key>ProgramArguments</key>
    <array>
        <string>VENV_PYTHON_PLACEHOLDER</string>
        <string>-m</string>
        <string>src.ingestion</string>
    </array>

    <key>WorkingDirectory</key>
    <string>REPO_ROOT_PLACEHOLDER</string>

    <!-- Time substituted by scripts/install_launchd.sh from INGESTION_HOUR / INGESTION_MINUTE in .env -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>HOUR_PLACEHOLDER</integer>
        <key>Minute</key>
        <integer>MINUTE_PLACEHOLDER</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>REPO_ROOT_PLACEHOLDER/logs/ingestion.log</string>

    <key>StandardErrorPath</key>
    <string>REPO_ROOT_PLACEHOLDER/logs/ingestion.err</string>

    <!-- Restart on crash -->
    <key>KeepAlive</key>
    <false/>

    <!-- Give the job enough time to run (5 min max) -->
    <key>TimeOut</key>
    <integer>300</integer>
</dict>
</plist>

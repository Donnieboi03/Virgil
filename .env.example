# ─── PHASE 0: Notion ─────────────────────────────────────────────────────────
# Internal Integration Secret from notion.so/my-integrations
NOTION_TOKEN=secret_

# Database IDs (32-char hex, from the Share link URL of each DB)
# Week 1 required:
NOTES_DB_ID=
TASKS_DB_ID=

# Week 2-3 required (create DBs, then fill these in):
CONTACTS_DB_ID=
PROJECTS_DB_ID=

# Week 9-12 required:
OPPORTUNITIES_DB_ID=
DECISIONS_DB_ID=

# ─── PHASE 1: Google ─────────────────────────────────────────────────────────
# Your local timezone string (used for date-stamping briefings + calendar queries)
# Find yours: python3 -c "import zoneinfo; print(sorted(zoneinfo.available_timezones()))"
TIMEZONE=America/Los_Angeles

# ─── PHASE 1: Schedule ───────────────────────────────────────────────────────
# What time should the daily briefing run? Uses your Mac's local system clock
# (System Settings → General → Date & Time), NOT the TIMEZONE above.
# Hour 0-23, Minute 0-59. Edit then rerun ./scripts/install_launchd.sh to apply.
INGESTION_HOUR=5
INGESTION_MINUTE=0

# ─── PHASE 1: News feeds ─────────────────────────────────────────────────────
# Comma-separated RSS feed URLs for the morning briefing.
# Default: Hacker News front page only (startup/tech). Add more URLs separated
# by commas if you want broader coverage (e.g. Ars Technica, Politico).
NEWS_RSS_FEEDS=https://hnrss.org/frontpage

# Optional: NewsAPI.org key for fallback/additional sources (free tier = 100 req/day)
NEWS_API_KEY=

# ─── PHASE 2: Composio ───────────────────────────────────────────────────────
# From app.composio.dev → Settings → API Keys
COMPOSIO_API_KEY=

# ─── PHASE 2: OpenRouter ─────────────────────────────────────────────────────
# From openrouter.ai → Keys
OPENROUTER_API_KEY=

# Model string passed to OpenRouter for task execution
# Cheap/fast default — upgrade to a reasoning model for complex tasks
LLM_MODEL=openai/gpt-4.1-mini

# ─── PHASE 2: Hermes ─────────────────────────────────────────────────────────
# WIP limit: max number of Tasks in Status=Processing at once
HERMES_WIP_LIMIT=5

# DLQ throttle: if open failures exceed this, slow Task ingestion
HERMES_DLQ_THRESHOLD=20

# Execution poll interval in seconds
HERMES_POLL_INTERVAL=60

# ─── PHASE 5: Obsidian ───────────────────────────────────────────────────────
# Absolute path to your Obsidian vault root
OBSIDIAN_VAULT_PATH=/Users/donnieb/Desktop/Code/Virgil/obsidian

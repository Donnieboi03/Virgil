# ─── PHASE 0: Notion ─────────────────────────────────────────────────────────
# Internal Integration Secret from notion.so/my-integrations
NOTION_TOKEN=secret_

# Database IDs (32-char hex, from the Share link URL of each DB)
# Week 1 required:
NOTES_DB_ID=
TASKS_DB_ID=

# Week 2-3 required (create DBs, then fill these in):
CONTACTS_DB_ID=
PROJECTS_DB_ID=

# Week 9-12 required:
OPPORTUNITIES_DB_ID=
DECISIONS_DB_ID=

# ─── PHASE 1: Google ─────────────────────────────────────────────────────────
# Your local timezone string (used for date-stamping briefings + calendar queries)
# Find yours: python3 -c "import zoneinfo; print(sorted(zoneinfo.available_timezones()))"
TIMEZONE=America/Los_Angeles

# ─── PHASE 1: Schedule ───────────────────────────────────────────────────────
# What time should the daily briefing run? Uses your Mac's local system clock
# (System Settings → General → Date & Time), NOT the TIMEZONE above.
# Hour 0-23, Minute 0-59. Edit then rerun ./scripts/install_launchd.sh to apply.
INGESTION_HOUR=5
INGESTION_MINUTE=0

# ─── PHASE 1: News feeds ─────────────────────────────────────────────────────
# Comma-separated RSS feed URLs for the morning briefing.
# HN provides title-only (its RSS summary is metadata, not editorial prose).
# Ars Technica and The Verge ship real descriptions, so the briefing has
# context to feed the extractor. Add or remove feeds as you like.
NEWS_RSS_FEEDS=https://hnrss.org/frontpage,https://feeds.arstechnica.com/arstechnica/index,https://www.theverge.com/rss/index.xml

# Optional: NewsAPI.org key for fallback/additional sources (free tier = 100 req/day)
NEWS_API_KEY=

# ─── PHASE 1.5: LLM (Daily Briefing → Draft Tasks extractor) ─────────────────
# Auto-detect: OpenRouter if OPENROUTER_API_KEY is set, else Gemini if GOOGLE_API_KEY.
# Force: LLM_PROVIDER=openrouter | gemini

OPENROUTER_API_KEY=
LLM_MODEL=openai/gpt-4.1-mini

# Google AI Studio — aistudio.google.com → Get API key
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MODEL=gemini-3.0-flash

# Integration tests (pytest --run-integration): a Daily Briefing page ID
TEST_BRIEFING_PAGE_ID=

# ─── PHASE 2: Composio ───────────────────────────────────────────────────────
# From app.composio.dev → Settings → API Keys
COMPOSIO_API_KEY=

# ─── PHASE 2: Hermes ─────────────────────────────────────────────────────────
# WIP limit: max number of Tasks in Status=Processing at once
HERMES_WIP_LIMIT=5

# DLQ throttle: if open failures exceed this, slow Task ingestion
HERMES_DLQ_THRESHOLD=20

# Execution poll interval in seconds
HERMES_POLL_INTERVAL=60

# ─── PHASE 5: Obsidian ───────────────────────────────────────────────────────
# Absolute path to your Obsidian vault root
OBSIDIAN_VAULT_PATH=/Users/donnieb/Desktop/Code/Virgil/obsidian
